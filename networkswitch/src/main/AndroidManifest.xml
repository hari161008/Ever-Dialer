<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Needed by "Switch Based On App Launched" to detect which app is currently in the foreground. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Needed so the automation service can restart itself after the device reboots. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exempts the standard launcher-intent app enumeration from package-visibility filtering,
         so the app picker in "Switch Based On App Launched" can list all installed apps. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application>

        <activity
            android:name="com.supernova.networkswitch.presentation.ui.activity.MainActivity"
            android:exported="true"
            android:label="@string/ns_app_name"
            android:theme="@style/Theme.NetworkSwitch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.supernova.networkswitch.presentation.ui.activity.SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:parentActivityName="com.supernova.networkswitch.presentation.ui.activity.MainActivity"
            android:theme="@style/Theme.NetworkSwitch" />

        <service
            android:name="com.supernova.networkswitch.service.NetworkTileService"
            android:exported="true"
            android:icon="@drawable/ic_5g_big"
            android:label="@string/network_switch"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Background automation: screen state / battery saver / app launch based switching -->
        <service
            android:name="com.supernova.networkswitch.service.AutomationService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Automatically switches the configured network mode based on screen state, battery saver state, or the foreground app" />
        </service>

        <receiver
            android:name="com.supernova.networkswitch.service.AutomationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
