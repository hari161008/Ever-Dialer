<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>

        <activity
            android:name="com.supernova.networkswitch.presentation.ui.activity.MainActivity"
            android:exported="true"
            android:label="@string/ns_app_name"
            android:theme="@style/Theme.NetworkSwitch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.supernova.networkswitch.presentation.ui.activity.SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:parentActivityName="com.supernova.networkswitch.presentation.ui.activity.MainActivity"
            android:theme="@style/Theme.NetworkSwitch" />

        <service
            android:name="com.supernova.networkswitch.service.NetworkTileService"
            android:exported="true"
            android:icon="@drawable/ic_5g_big"
            android:label="@string/network_switch"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>

</manifest>
